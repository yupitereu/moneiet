{
  "name": "moneiet-client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ignore-pattern .next"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write --config ../../.prettierrc",
      "eslint . --ignore-pattern .next --fix"
    ],
    "*.{scss,css}": [
      "stylelint --fix"
    ]
  },
  "dependencies": {
    "axios": "1.16.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@repo/project-config": "workspace:*",
    "@repo/ui": "workspace:*",
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  },
  "type": "module"
}
