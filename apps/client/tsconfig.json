{
  "extends": "@repo/project-config/typescript/apps.json",
  "compilerOptions": {
    "plugins": [{"name": "next"}],
    "noEmit": true,
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./*"],
    },
    "module": "esnext",
  },
  "include": ["next-env.d.ts", "next.config.mjs", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
